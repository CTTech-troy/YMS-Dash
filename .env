# Vite env — restart dev server after changes.
# Dev: leave VITE_API_URL empty to use Vite proxy (/api → http://127.0.0.1:5000). Start backend: cd backend && npm run dev
# VITE_API_URL=http://localhost:5000
# Production / direct API:
# VITE_API_URL=https://yms-backend-a2x4.onrender.com
VITE_API_URL=http://localhost:5000

# Supabase — copy from Supabase Dashboard → Settings → API (anon key is public but rotate if leaked)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
